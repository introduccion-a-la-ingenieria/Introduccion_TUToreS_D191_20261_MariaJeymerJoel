[database]
# Pega aquí la URL de conexión de Supabase (con Connection Pooling activado)
# La encuentras en: Project Settings → Database → Connection String → URI
# Asegúrate de activar "Use connection pooling" y usar el puerto 6543
url = "postgresql://postgres.TU_PROJECT_ID:TU_CONTRASEÑA@aws-0-REGION.pooler.supabase.com:6543/postgres"
